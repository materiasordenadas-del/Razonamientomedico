:root{--bg:#f4f6fb;--surface:#fff;--ink:#172033;--muted:#6a7485;--line:#d8deea;--dark:#172033;--accent:#3858e9;--accent2:#eef2ff;--soft:#f8fafc;--good:#126c42;--warn:#a34b00;--danger:#a32525;--dx1:rgba(49,104,230,.22);--dx2:rgba(27,160,97,.20);--dx3:rgba(231,134,37,.22)}
*{box-sizing:border-box} body{margin:0;background:var(--bg);color:var(--ink);font-family:Inter,ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;font-size:14px;line-height:1.42}
button,input,textarea,select{font:inherit} button{cursor:pointer}
#startScreen{min-height:100vh;display:grid;place-items:center;padding:24px;background:radial-gradient(circle at top,#eef2ff 0,#f7f8fc 46%,#edf0f7 100%)}
.start-card{width:min(680px,100%);background:#fff;border:1px solid var(--line);border-radius:22px;padding:54px 32px;text-align:center;box-shadow:0 18px 60px rgba(25,39,75,.11)}
.start-card h1{font-size:40px;margin:0 0 18px;letter-spacing:-.03em}.start-card p{color:var(--muted);font-size:16px;margin:0 0 34px}.start-card .continue{background:var(--dark);color:white;border:0;border-radius:12px;padding:12px 28px;font-weight:750}
#app{display:none;min-height:100vh}.topbar{background:var(--dark);color:#fff;padding:12px 16px;position:sticky;top:0;z-index:20;box-shadow:0 1px 8px rgba(0,0,0,.18)}
.topbar-inner{max-width:1700px;margin:auto;display:flex;align-items:center;gap:12px}.topbar-title{font-weight:800;white-space:nowrap}.topbar-meta{font-size:12px;color:#cbd5e1}.topbar-spacer{flex:1}.small-btn{border:1px solid #52607a;background:transparent;color:white;border-radius:9px;padding:7px 10px;font-size:12px}
.tabs{display:flex;gap:6px;overflow:auto;padding:10px 14px;background:#fff;border-bottom:1px solid var(--line);position:sticky;top:48px;z-index:15}.tab{white-space:nowrap;border:1px solid var(--line);background:#fff;color:#34405a;border-radius:9px;padding:7px 10px;font-size:12px;font-weight:700}.tab.active{background:#e9edff;border-color:#9aaaf9;color:#233baf}
#workspace{max-width:1700px;margin:auto;display:grid;grid-template-columns:minmax(0,1fr) 330px;gap:14px;padding:14px}.pad-collapsed #workspace{grid-template-columns:minmax(0,1fr) 190px}.pad-collapsed .pad-body{display:none}.pad-collapsed .pad{padding:8px;overflow:hidden;align-self:start}.pad-collapsed .pad-header{justify-content:space-between}.pad-collapsed .pad h2{font-size:12px;writing-mode:horizontal-tb;margin:0;white-space:nowrap}.pad-collapsed .pad-toggle{width:30px;padding:5px}
.module{display:none}.module.active{display:block}.module-intro{margin-bottom:10px}.module-intro h1{font-size:21px;margin:0}.module-intro p{color:var(--muted);margin:4px 0 0}
.card{background:var(--surface);border:1px solid var(--line);border-radius:15px;padding:14px;margin-bottom:12px;box-shadow:0 2px 9px rgba(26,41,76,.035)}
.card h2{font-size:16px;margin:0 0 8px}.card h3{font-size:14px;margin:12px 0 6px}.subtle{font-size:12px;color:var(--muted)}
.m1-grid{display:grid;grid-template-columns:minmax(240px,.8fr) minmax(480px,1.7fr);gap:12px}.triage-panel{align-self:start}.conversation-panel{min-width:0}.section-title{font-weight:800;font-size:13px;margin:0 0 8px}.patient-identity{margin:0 0 9px;padding:8px 10px;border-radius:9px;background:#f3f5fa;border:1px solid #dbe1ec;font-size:13px}.data-row,.selectable{display:flex;align-items:flex-start;gap:8px;border:1px solid #dbe1ec;border-radius:10px;padding:8px 9px;background:#fff;margin:6px 0;max-width:100%}.data-row:hover,.selectable:hover{border-color:#9aaaf9}.selected{background:#f0f3ff!important;border-color:#6f82ef!important}.data-row input,.selectable input{width:16px;height:16px;accent-color:var(--accent);margin:1px 0 0}.fact-label{display:block;min-width:0}.fact-hint{display:block;font-size:11px;color:var(--muted);margin-top:2px}
.dialogue{border-left:3px solid #d9e0ff;background:#fbfcff;border-radius:0 11px 11px 0;padding:10px 10px 10px 12px;margin:8px 0}.doctor{font-weight:750;margin:0 0 5px}.patient-details{margin:0}.patient-details summary{list-style:none;display:flex;gap:8px;align-items:flex-start;cursor:pointer;color:#243354}.patient-details summary::-webkit-details-marker{display:none}.patient-details summary::before{content:'▸';color:#6b7feb;line-height:1.4;font-size:13px}.patient-details[open] summary::before{content:'▾'}.patient-text{flex:1}.patient-check{width:16px;height:16px;accent-color:var(--accent);margin-top:2px}.deeper{margin:8px 0 0 23px;padding:9px;background:#fff;border:1px solid #e1e6f0;border-radius:9px}.deeper .dialogue{margin:7px 0;background:#fbfcff}
.expandable-finding{border:1px solid #dbe1ec;border-radius:10px;background:#fff;margin:6px 0;overflow:hidden}.expandable-finding summary{list-style:none;display:flex;gap:8px;align-items:flex-start;cursor:pointer;padding:8px 9px;color:#243354}.expandable-finding summary::-webkit-details-marker{display:none}.expandable-finding summary::before{content:'▸';color:#6b7feb;line-height:1.4;font-size:13px}.expandable-finding[open] summary::before{content:'▾'}.nested-selectable{margin:6px 0 0}
.accordion{border:1px solid var(--line);border-radius:12px;background:#fff;margin:8px 0;overflow:hidden}.accordion summary{padding:10px 12px;background:#fafbfe;font-weight:800;cursor:pointer;list-style:none}.accordion summary::-webkit-details-marker{display:none}.accordion summary::after{content:'＋';float:right;color:#667085}.accordion[open] summary::after{content:'−'}.accordion-body{padding:10px 12px}
.category-chip{display:inline-block;background:#edf1ff;color:#3346a7;padding:2px 7px;border-radius:999px;font-size:11px;font-weight:700;margin:0 4px 5px 0}
.guidance{border-left:3px solid #aab6ee;background:#f7f8ff;border-radius:0 10px 10px 0;padding:9px 11px;color:#4f5d88;font-size:12px;margin:8px 0}.field{margin:12px 0}.field-title{font-size:12px;font-weight:850;letter-spacing:.03em;text-transform:uppercase;margin-bottom:3px}.field-instruction{font-size:12px;color:var(--muted);margin-bottom:5px}.field textarea,.field input{width:100%;border:1px solid var(--line);border-radius:10px;padding:9px 10px;background:#fff;color:var(--ink)}.field textarea{min-height:84px;resize:vertical}.field input{min-height:39px}.copy-prev{font-size:12px;border:1px solid #b7c2e8;background:#f8f9ff;border-radius:8px;padding:6px 8px;color:#4056b9;margin:5px 0 8px}
.tier-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}.tier-card{border:1px solid var(--line);border-radius:11px;padding:10px;background:#fcfdff}.tier-card h4{margin:0 0 5px;font-size:13px}.tier-card p{margin:0 0 8px;color:var(--muted);font-size:12px}.tier-card input,.tier-card textarea{width:100%;border:1px solid var(--line);border-radius:8px;padding:8px;margin-top:6px}.tier-card textarea{min-height:62px;resize:vertical}.diagnosis-picker{position:relative}.diagnosis-selected{display:flex;align-items:center;justify-content:space-between;gap:8px;border:1px solid #b8c4f5;background:#f3f5ff;border-radius:9px;padding:7px 8px;margin:6px 0}.diagnosis-selected span{min-width:0}.diagnosis-selected b{display:block;font-size:12px}.diagnosis-selected small{display:block;color:var(--muted);font-size:11px}.diagnosis-x{border:0;background:#fff;color:#4056b9;border-radius:999px;width:22px;height:22px;line-height:1;font-weight:850}.diagnosis-suggestions{position:absolute;z-index:30;left:0;width:min(620px,calc(100vw - 48px));max-height:360px;overflow:auto;background:#fff;border:1px solid var(--line);border-radius:10px;box-shadow:0 8px 22px rgba(23,32,51,.12);margin-top:4px}.diagnosis-suggestions:empty{display:none}.diagnosis-option{display:flex;align-items:center;justify-content:space-between;gap:12px;width:100%;border:0;background:#fff;text-align:left;padding:6px 10px;color:var(--ink);line-height:1.15;white-space:nowrap}.diagnosis-option span{min-width:0}.diagnosis-option:hover{background:#f3f5ff}.diagnosis-option small{flex:0 0 auto;color:var(--muted);font-size:10px}.diagnosis-option.manual{border-top:1px solid var(--line)}
.pad{position:sticky;top:105px;align-self:start;max-height:calc(100vh - 120px);overflow:auto;padding:12px}.pad-header{display:flex;justify-content:space-between;align-items:center;gap:6px}.pad h2{margin:0;font-size:15px}.pad-toggle{border:1px solid var(--line);background:#fff;border-radius:8px;padding:5px 7px;color:#49566e}.pad-meta{display:flex;gap:5px;flex-wrap:wrap;margin:9px 0}.badge{font-size:11px;border-radius:999px;background:#f0f2f8;color:#4b586f;padding:3px 7px}.pad details{border:1px solid #e2e6ef;border-radius:9px;margin:6px 0;background:#fff}.pad summary{cursor:pointer;padding:7px 8px;font-size:12px;font-weight:750}.pad ul{margin:0;padding:0 10px 8px 24px;font-size:12px}.pad li{margin:4px 0}.pad .empty{font-size:12px;color:var(--muted);padding:9px 0}.pad .pad-note{font-size:12px;line-height:1.35;color:#3b4861;background:#f8f9fc;border:1px dashed #d8dee9;border-radius:9px;padding:8px;margin:6px 0}.pad-tier-box{background:#f8f9fc;border:1px solid #d8dee9;border-radius:10px;padding:8px;margin:6px 0}.pad-tier-item{border-top:1px solid #e4e8ef;padding:7px 0}.pad-tier-item:first-child{border-top:0;padding-top:0}.pad-tier-item:last-child{padding-bottom:0}.pad-tier-label{font-size:11px;font-weight:850;color:#667085;text-transform:uppercase}.pad-tier-name{font-size:13px;color:#1f2937;margin-top:2px;line-height:1.3}
.lab-table{width:100%;border-collapse:collapse;font-size:13px}.lab-table th,.lab-table td{border:1px solid var(--line);padding:7px;text-align:left;vertical-align:top}.lab-table th{background:#f7f8fb;font-size:12px}.lab-check{width:16px;height:16px;accent-color:var(--accent)}
.venn-top{display:grid;grid-template-columns:1fr 1fr 1fr;gap:9px;margin:10px 0}.m5-card{width:max-content;min-width:100%}.m5-card .guidance,.m5-card .venn-top,.m5-card .venn-top+ .footer-actions,.m5-card .venn-layout{min-width:1092px}.venn-top .field{margin:0}.venn-layout{display:grid;grid-template-columns:300px minmax(780px,1fr);gap:12px;min-width:1092px}.finding-source{max-height:640px;overflow:auto}.finding-group{padding:8px 0;border-bottom:1px solid #e4e8f0}.finding-group:last-child{border:0}.finding-group-title{font-size:12px;font-weight:850;color:#37456c;margin:0 0 6px}.finding-chip{display:inline-flex;width:fit-content;max-width:100%;align-items:center;gap:4px;border:1px solid #cdd5e4;background:#fff;border-radius:999px;padding:5px 8px;margin:3px 3px 3px 0;font-size:12px;cursor:grab;user-select:none}.finding-chip:hover{border-color:#8093ef;background:#f5f6ff}.finding-chip .tag{font-size:10px;color:#6b7280}.venn-board{position:relative;height:650px;border:1px solid var(--line);border-radius:15px;overflow:hidden;background:radial-gradient(circle at 1px 1px,#e5e9f1 1px,transparent 1px);background-size:26px 26px}.venn-reset-button{position:absolute;right:14px;top:14px;z-index:20}.circle{position:absolute;width:350px;height:350px;border-radius:50%;pointer-events:none;border:2px solid}.circle.dx1{left:150px;top:115px;background:var(--dx1);border-color:#3865df}.circle.dx2{left:410px;top:115px;background:var(--dx2);border-color:#2b9a62}.circle.dx3{left:280px;top:305px;background:var(--dx3);border-color:#db8420}.zone{position:absolute;border:1px dashed #8b98ae;border-radius:10px;background:rgba(255,255,255,.74);padding:6px;overflow:auto}.zone-title{font-size:10px;font-weight:850;color:#3f4b61;margin-bottom:4px}.zone.z1{left:86px;top:188px;width:175px;height:132px}.zone.z2{left:651px;top:188px;width:175px;height:132px}.zone.z3{left:365px;top:543px;width:175px;height:88px}.zone.z12{left:400px;top:148px;width:185px;height:105px}.zone.z13{left:237px;top:424px;width:185px;height:96px}.zone.z23{left:552px;top:424px;width:185px;height:96px}.zone.z123{left:416px;top:327px;width:190px;height:100px;border:2px dashed #26324b}.zone.return{left:14px;bottom:14px;width:230px;height:94px;background:#fffdf7;border-color:#c59120}.drop-over{background:#fff2c7!important;border-color:#d89000!important}.placed{cursor:grab;font-size:11px;white-space:normal;padding:4px 6px;margin:3px;border-radius:8px;border:1px solid #cbd5e1;background:#fff}.placed small{color:#6a7485}.venn-log{width:100%;border-collapse:separate;border-spacing:0 4px;font-size:12px;margin-top:10px}.venn-log-table thead{display:none}.venn-log td{border:0;padding:5px 8px;text-align:left}.venn-log-heading td{font-weight:850;color:#37456c;background:#f3f5fa;border:1px solid #dbe1ec;border-radius:9px}.venn-log-finding td{background:#fff;border-left:3px solid #c8d1ff;border-radius:7px}.venn-log-finding small{color:#667085;font-weight:750}.eval-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.eval-col{border:1px solid var(--line);border-radius:12px;padding:12px}.eval-col h3{margin:0 0 8px}.placeholder{color:#8090a7;font-size:12px;border:1px dashed #cad2e1;border-radius:9px;padding:10px;background:#fafbfd}.eval-row{border-top:1px solid #e4e8ef;padding:9px 0}.eval-row:first-child{border-top:0}.eval-label{font-size:11px;font-weight:850;text-transform:uppercase;color:#667085}.eval-value{font-size:13px;margin-top:2px;white-space:pre-wrap}.import-box{display:flex;gap:8px;align-items:center;flex-wrap:wrap}.action{background:var(--dark);color:#fff;border:0;border-radius:9px;padding:9px 11px;font-weight:750}.action.secondary{background:#475569}.action.light{background:#eef2ff;color:#3448ad;border:1px solid #c8d1ff}.warn{background:#9d4a09}.footer-actions{display:flex;gap:8px;flex-wrap:wrap;justify-content:flex-end;margin-top:14px}
@media(max-width:1200px){#workspace{grid-template-columns:1fr}.pad{position:static;max-height:none}.pad-collapsed #workspace{grid-template-columns:1fr}.pad-collapsed .pad{display:none}.m1-grid,.venn-layout{grid-template-columns:1fr}.venn-layout .card{overflow:auto}.venn-board{min-width:850px}.tier-grid,.venn-top,.eval-grid{grid-template-columns:1fr}}
.management-select{min-height:calc(100vh - 150px);display:flex;flex-direction:column;gap:14px}.management-instructions{background:#fff;border:1px solid var(--line);border-radius:15px;padding:16px}.management-instructions p{margin:4px 0;color:#3b4861}.management-choice-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px;flex:1}.management-choice{display:block;text-align:left;border:1px solid var(--line);border-radius:15px;background:#fff;padding:24px;cursor:pointer;color:var(--ink);min-height:460px;box-shadow:0 2px 9px rgba(26,41,76,.035)}.management-choice:hover{border-color:#7f91f2;background:#f8f9ff}.management-choice h2{margin:0 0 16px;font-size:24px}.management-choice h3{margin:18px 0 8px;font-size:14px}.management-choice p,.management-choice li{font-size:14px;line-height:1.45}.management-template{white-space:pre-wrap;background:#f8f9fc;border:1px dashed #d8dee9;border-radius:10px;padding:10px;font-size:12px;color:#3b4861}.guided-management{display:grid;gap:10px}.guided-section{border:1px solid var(--line);border-radius:12px;background:#fff;overflow:hidden}.guided-section summary{cursor:pointer;padding:12px 14px;font-weight:850;background:#f7f8fb}.guided-options{display:grid;grid-template-columns:repeat(auto-fit,minmax(210px,1fr));gap:8px;padding:12px}.guided-option{display:flex;gap:8px;align-items:flex-start;border:1px solid #dbe1ec;border-radius:10px;padding:8px 9px;background:#fff;font-size:13px}.guided-option.selected{background:#f0f3ff;border-color:#6f82ef}.guided-detail,.drug-form{border:1px solid #dbe1ec;border-radius:12px;margin:10px 12px 12px;padding:12px;background:#fcfdff}.guided-detail h4,.drug-form h4{margin:0 0 8px}.guided-detail input,.guided-detail textarea,.guided-detail select,.drug-form input,.drug-form textarea,.drug-form select,.guided-section select{width:100%;border:1px solid var(--line);border-radius:9px;padding:8px;margin:5px 0;background:#fff}.guided-detail textarea,.drug-form textarea,.required-precautions{min-height:78px;resize:vertical}.guided-inline{display:inline-flex;gap:6px;align-items:center;margin:5px 10px 5px 0;font-size:13px}.drug-tree{padding:12px}.drug-node{border-left:2px solid #d8dee9;margin:6px 0 6px 8px;padding-left:10px}.drug-node summary{background:transparent;padding:6px 0}.drug-row{margin:6px 0}.selected-drugs{display:grid;gap:10px}.drug-form-header{display:flex;justify-content:space-between;align-items:center;gap:10px}.required-precautions{width:calc(100% - 24px);margin:12px;border:1px solid var(--line);border-radius:9px;padding:10px}@media(max-width:900px){.management-choice-grid{grid-template-columns:1fr}.management-choice{min-height:0}}
.drug-panel{margin:12px;border:1px solid #d8e0ef;border-radius:16px;background:#fff;overflow:hidden;box-shadow:0 8px 20px rgba(31,48,84,.04)}.drug-panel-header{padding:14px 16px;background:#f4f7fc;border-bottom:1px solid #d8e0ef}.drug-panel-header h3{margin:0;font-size:15px;font-weight:900;letter-spacing:.03em;color:#1f3764}.drug-panel-header p{margin:3px 0 0;font-size:12px;color:#64748b}.drug-panel .drug-tree{padding:8px 10px 14px}.drug-panel .drug-node{border:0;border-bottom:1px solid #e5eaf3;margin:0;padding:0}.drug-panel .drug-node:last-child{border-bottom:0}.drug-panel .drug-node summary{display:flex;align-items:center;justify-content:space-between;gap:12px;list-style:none;background:#fff;padding:12px 2px;font-weight:850;color:#2a3f63;cursor:pointer}.drug-panel .drug-node summary::-webkit-details-marker{display:none}.drug-panel .drug-arrow{color:#6d83b7;font-size:13px;transition:transform .15s ease}.drug-panel .drug-node[open]>summary .drug-arrow{transform:rotate(180deg)}.drug-panel .drug-node-body{padding:0 0 8px}.drug-panel .drug-level-1{margin-left:10px;border-left:2px solid #dbe5f4;border-bottom:0;padding-left:10px}.drug-panel .drug-level-1>summary{font-size:13px}.drug-panel .drug-level-2{margin-left:10px;border-left:2px solid #dbe5f4;border-bottom:0;padding-left:10px}.drug-panel .drug-level-2>summary{font-size:12px;color:#61708a}.drug-panel .drug-level-3{margin-left:10px;border-left:2px solid #dbe5f4;border-bottom:0;padding-left:10px}.drug-panel .drug-level-3>summary{font-size:12px;color:#6b7890}.drug-chip-list{display:grid;gap:7px;padding:0 0 8px 10px}.drug-chip{width:100%;text-align:left;border:1px solid #b9cdf8;border-radius:11px;background:#eef5ff;color:#244d8f;padding:8px 11px;font-weight:800;box-shadow:0 3px 8px rgba(38,70,120,.05);cursor:pointer}.drug-chip:hover{border-color:#789fed;background:#e6f0ff}.drug-chip.selected{background:#dfeaff;border-color:#4f7fe5}.selected-drugs{margin:12px;display:grid;gap:10px}.selected-drugs>h3{margin:4px 0 0;font-size:14px;color:#2a3f63}.basic-drug-order .subtle{margin:3px 0 0}.drug-form{box-shadow:0 4px 14px rgba(31,48,84,.04)}
.drug-leaf-group{margin:8px 0 10px 10px;border-left:2px solid #dbe5f4;padding-left:10px}.drug-leaf-title{font-size:12px;font-weight:850;color:#6b7890;margin:8px 0 6px}
